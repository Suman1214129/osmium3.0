<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginBottom="12dp"
    android:background="@drawable/notification_card_bg"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:padding="16dp">

    <!-- Left Border -->
    <View
        android:id="@+id/notifBorder"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:layout_marginEnd="12dp"
        android:background="#D4AF37" />

    <!-- Icon -->
    <TextView
        android:id="@+id/notifEmoji"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/icon_bubble_bg"
        android:gravity="center"
        android:text="📚"
        android:textSize="20sp" />

    <!-- Content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvNotifTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/public_sans"
                android:text="Advanced Data Structures"
                android:textColor="#1E1E1E"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvNotifTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:fontFamily="@font/public_sans"
                android:text="2h"
                android:textColor="#9E9E9E"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvNotifMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/public_sans"
            android:text="A new course is now available"
            android:textColor="#616161"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvNotifTag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_pill_gray_light"
            android:fontFamily="@font/public_sans"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="New Course"
            android:textColor="#B8935A"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Unread Badge -->
    <View
        android:id="@+id/unreadBadge"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="12dp"
        android:background="@drawable/unread_badge"
        android:visibility="visible" />

</LinearLayout>
