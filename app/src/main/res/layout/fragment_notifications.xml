<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F5F3"
    android:orientation="vertical"
    tools:context=".ui.notifications.NotificationsFragment">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="56dp"
        android:paddingBottom="8dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_left"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#1E1E1E" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:text="Notifications"
                android:fontFamily="@font/baskervville"
                android:textColor="#1E1E1E"
                android:textSize="34sp"
                android:letterSpacing="-0.01"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Status Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:gravity="center_vertical">

        <View
            android:id="@+id/unreadDot"
            android:layout_width="7dp"
            android:layout_height="7dp"
            android:background="@drawable/circle_dot_gold" />

        <TextView
            android:id="@+id/tvUnreadCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="4 unread"
            android:fontFamily="@font/public_sans"
            android:textColor="#616161"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btnMarkAllRead"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Clear all"
            android:fontFamily="@font/public_sans"
            android:textColor="#B8935A"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="?attr/selectableItemBackground"
            android:padding="4dp" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EBEBEB"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="14dp" />

    <!-- Filter Chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp">

        <LinearLayout
            android:id="@+id/filterChipsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All"
                android:fontFamily="@font/public_sans"
                android:textSize="12.5sp"
                android:textStyle="bold"
                android:textColor="#1E1E1E"
                android:background="@drawable/chip_active"
                android:paddingHorizontal="15dp"
                android:paddingVertical="7dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chipUnread"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Unread"
                android:fontFamily="@font/public_sans"
                android:textSize="12.5sp"
                android:textStyle="bold"
                android:textColor="#6B6B6B"
                android:background="@drawable/chip_inactive"
                android:paddingHorizontal="15dp"
                android:paddingVertical="7dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chipCourse"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Course"
                android:fontFamily="@font/public_sans"
                android:textSize="12.5sp"
                android:textStyle="bold"
                android:textColor="#6B6B6B"
                android:background="@drawable/chip_inactive"
                android:paddingHorizontal="15dp"
                android:paddingVertical="7dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chipTest"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Test Result"
                android:fontFamily="@font/public_sans"
                android:textSize="12.5sp"
                android:textStyle="bold"
                android:textColor="#6B6B6B"
                android:background="@drawable/chip_inactive"
                android:paddingHorizontal="15dp"
                android:paddingVertical="7dp"
                android:layout_marginEnd="8dp" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Scroll Area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:paddingBottom="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Today Section -->
            <TextView
                android:id="@+id/labelToday"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TODAY"
                android:fontFamily="@font/public_sans"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#9E9E9E"
                android:letterSpacing="0.1"
                android:paddingHorizontal="24dp"
                android:paddingTop="20dp"
                android:paddingBottom="10dp" />

            <LinearLayout
                android:id="@+id/notificationsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp" />

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="60dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅"
                    android:textSize="52sp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="All caught up"
                    android:fontFamily="@font/baskervville"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#1E1E1E"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="You've seen everything.\nCheck back later for new updates."
                    android:fontFamily="@font/public_sans"
                    android:textSize="14sp"
                    android:textColor="#616161"
                    android:gravity="center"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
